{
  "pluginAlias": "LollipopCamera",
  "pluginType": "platform",
  "singular": false,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Platform Name",
        "type": "string",
        "default": "Lollipop"
      },
      "cameras": {
        "title": "Cameras",
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "title": "Camera Name",
              "type": "string",
              "placeholder": "Andrea's Room"
            },
            "ip": {
              "title": "Camera IP Address",
              "type": "string",
              "placeholder": "192.168.4.24",
              "description": "Local IP of the Lollipop camera. Use a DHCP reservation to keep it fixed."
            },
            "hksv": {
              "title": "Enable HomeKit Secure Video",
              "type": "boolean",
              "default": true
            },
            "enableSoundMachine": {
              "title": "Enable Sound Machine",
              "type": "boolean",
              "default": true
            },
            "movementSensitivity": {
              "title": "Movement Sensitivity",
              "type": "integer",
              "default": 10,
              "oneOf": [
                { "title": "Disabled", "enum": [0] },
                { "title": "High", "enum": [2] },
                { "title": "Medium", "enum": [5] },
                { "title": "Low", "enum": [10] }
              ],
              "description": "Motion level threshold (0 = disabled, 2 = high, 5 = medium, 10 = low)."
            },
            "enableCryingDetectionSensor": {
              "title": "Enable Crying Detection Sensor",
              "type": "boolean",
              "default": false
            },
            "enableCrossingDetectionSensor": {
              "title": "Enable Crossing Detection Sensor",
              "type": "boolean",
              "default": false
            },
            "enableNoiseSensor": {
              "title": "Enable Noise Sensor",
              "type": "boolean",
              "default": false
            },
            "contactSensors": {
              "title": "Use Contact Sensors instead of Motion Sensors",
              "type": "boolean",
              "default": false
            }
          },
          "required": ["name", "ip"]
        }
      },
      "debug": {
        "title": "Enable Debug Logging",
        "type": "boolean",
        "default": false
      }
    },
    "required": ["name", "cameras"]
  }
}
